{
  "name": "koassi/filament-highcharts",
  "description": "Filament Integration for Highcharts",
  "keywords": [
    "filament",
    "laravel",
    "highcharts"
  ],
  "authors": [
    {
      "name": "koassi",
      "email": "akfred2007@outlook.com",
      "role": "Developer"
    }
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "filament/filament": "^4.0|^5.0",
    "spatie/laravel-package-tools": "^1.92"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^9.0",
    "pestphp/pest": "^3.0|^2.0"
  },
  "autoload": {
    "psr-4": {
      "Koassi\\FilamentHighcharts\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Koassi\\FilamentHighcharts\\Tests\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Koassi\\FilamentHighcharts\\FilamentHighchartsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}

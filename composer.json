{
    "name": "koassi/filament-highcharts",
    "description": "Filament Integration for Highcharts",
    "keywords": [
        "filament",
        "laravel",
        "highcharts"
    ],
    "homepage": "https://github.com/KoassiAkakpo/filament-highcharts",
    "support": {
        "issues": "https://github.com/KoassiAkakpo/filament-highcharts/issues",
        "source": "https://github.com/KoassiAkakpo/filament-highcharts"
    },
    "authors": [
        {
            "name": "koassi",
            "email": "akfred2007@outlook.com",
            "role": "Developer"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "autoload": {
        "psr-4": {
            "Koassi\\FilamentHighcharts\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Koassi\\FilamentHighcharts\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Koassi\\FilamentHighcharts\\FilamentHighchartsServiceProvider"
            ],
            "aliases": {
                "FilamentHighcharts": "Koassi\\FilamentHighcharts\\Facades\\FilamentHighcharts"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0|^11.1",
        "pestphp/pest": "^4.1|^5.0"
    }
}

{
    protected static ?string $chartId = '$CHART_ID$';
    protected static ?string $heading = '$CLASS_NAME$';

    protected function getOptions(): array
    {
        return [
            'chart' => ['type' => 'variablepie', 'styledMode' => true],
            'title' => ['text' => 'Variable Pie Chart'],

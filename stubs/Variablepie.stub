                [
                    'name' => 'Variable Pie',
                    'data' => [
                        ['name' => 'A', 'y' => 5, 'z' => 100],
                        ['name' => 'B', 'y' => 3, 'z' => 80],
                        ['name' => 'C', 'y' => 2, 'z' => 60],
                        ['name' => 'D', 'y' => 4, 'z' => 40],
                    ],
                ],
            ],
            'credits' => ['enabled' => false],
        ];
    }
}
